# MySQL Connection
# 同一 MySQL 实例上要备份的「所有库名」写在 MYSQL_DATABASES 里：
# 英文逗号分隔、不要空格，例如：app,logs,analytics,archive
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASES=db1,db2,db3

# Server
SERVER_PORT=3000
# production：每日 3:00 CRON 备份；非 production：每 120s 用 interval 触发（便于本地测）
NODE_ENV=development

# Backup
BACKUP_DIR=./db_backups

# SQLite (default: project root mysql-maintainer.db)
SQLITE_DB_PATH=./mysql-maintainer.db
